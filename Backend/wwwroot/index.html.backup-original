    <script>
        // Fun+º+Áes para o Modal do Dashboard (Inline para simplicidade no prot+¦tipo)
        function abrirModalDash() {
            document.getElementById('modalLoginDash').classList.remove('hidden');
            document.getElementById('dashUser').focus();
        }

        function fecharModalDash() {
            document.getElementById('modalLoginDash').classList.add('hidden');
            document.getElementById('dashUser').value = '';
            document.getElementById('dashPass').value = '';
        }

        function validarAcessoDash() {
            const user = document.getElementById('dashUser').value;
            const pass = document.getElementById('dashPass').value;

            // Valida+º+úo simples (igual ao backend Python)
            if ((user === 'admin' && pass === 'admin123') ||
                (user === 'Guerra' && pass === 'Guerr@2026') ||
                (user === 'Jean' && pass === 'Je@n2026') ||
                (user === 'Analista' && pass === 'Analista@2026')) {
                // Sucesso! Cria formul+írio oculto para login via POST
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = 'https://Sentinel-dashboard-557004456190.us-central1.run.app/login';
                form.target = '_blank'; // Abre em nova aba

                const inputUser = document.createElement('input');
                inputUser.type = 'hidden';
                inputUser.name = 'username';
                inputUser.value = user;

                const inputPass = document.createElement('input');
                inputPass.type = 'hidden';
                inputPass.name = 'password';
                inputPass.value = pass;

                form.appendChild(inputUser);
                form.appendChild(inputPass);
                document.body.appendChild(form);

                form.submit();
                document.body.removeChild(form); // Limpa

                fecharModalDash();
            } else {
                alert('Credenciais inv+ílidas!');
            }
        }

        // Enter para enviar
        document.getElementById('dashPass').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                validarAcessoDash();
            }
        });
    </script>
