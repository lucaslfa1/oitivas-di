{
  "AzureSpeech": {
    "Enabled": true,
    "SpeechToTextEnabled": true,
    "SpeechToTextKey": "<AZURE_SPEECH_TO_TEXT_KEY>",
    "SpeechToTextRegion": "eastus2",
    "SpeechToTextApiVersion": "2025-10-15",
    "SpeechToTextLocale": "pt-BR",
    "SpeechToTextUseDiarization": true,
    "SpeechToTextMaxSpeakers": 2,
    "SpeechToTextUsePhraseList": true,
    "SpeechToTextPhraseList": [
      "Opentech",
      "Operador BAS",
      "sinistro",
      "CEAGESP"
    ],
    "SubscriptionKey": "<AZURE_OPENAI_WHISPER_KEY>",
    "Region": "eastus2",
    "Endpoint": "https://<resource>.openai.azure.com/",
    "DeploymentName": "<whisper_deployment_name>"
  }
}
