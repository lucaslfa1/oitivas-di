# =============================================================================
# Sentinel — Contrato de variáveis de ambiente (EXEMPLO)
# =============================================================================
# Copie para um arquivo NÃO versionado (.env / appsettings.Local.json) e
# preencha com valores reais. NENHUM segredo deve ser commitado.
# Cada ambiente/empresa usa as próprias chaves. Ver docs/PLANO_MELHORIA_HANDOFF.md.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend (.NET / SinistroAPI)
# Em desenvolvimento, prefira Backend/appsettings.Local.json (já no .gitignore).
# Em produção (Cloud Run / contêiner), injete como variáveis de ambiente.
# A notação "__" mapeia para seções aninhadas do appsettings.
# ---------------------------------------------------------------------------
AzureSpeech__SpeechToTextKey=
AzureSpeech__SpeechToTextRegion=eastus
AzureSpeech__SubscriptionKey=
AzureSpeech__Region=eastus2
AzureSpeech__Endpoint=

AzureOpenAI__ApiKey=
AzureOpenAI__Endpoint=
AzureOpenAI__DeploymentName=gpt-4o

AzureTextAnalytics__Key=
AzureTextAnalytics__Endpoint=

# URL do microsserviço de mídia (sentinel-cortex). Em docker-compose: http://sentinel-cortex:8000
MediaProcessor__BaseUrl=http://localhost:8000

# Caminho do banco SQLite (no contêiner costuma ser /data/sinistros.db)
DB_PATH=

# ---------------------------------------------------------------------------
# sentinel-cortex (Python / FastAPI) — prefixo SENTINEL_
# ---------------------------------------------------------------------------
SENTINEL_SECRET_KEY=
SENTINEL_DEV_ADMIN_PASSWORD=
SENTINEL_CORS_ORIGINS=["http://localhost:5150"]

# ---------------------------------------------------------------------------
# dashboard-kpi (Python / Dash)
# ---------------------------------------------------------------------------
# URL de autenticação do backend (em docker-compose: http://backend:8080/api/auth/login)
BACKEND_AUTH_URL=http://localhost:5252/api/auth/login
# Chave de sessão Flask (defina um valor fixo em produção p/ não invalidar sessões a cada boot)
SECRET_KEY=
