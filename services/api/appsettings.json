{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5150",
      "http://localhost:3000"
    ]
  },
  "Resilience": {
    "GeminiTimeoutMinutes": 15,
    "MaxInlineUploadMB": 10,
    "MaxRetries": 3
  },
  "UploadLimits": {
    "MaxRequestBodyMB": 500,
    "MaxImageUploadMB": 25,
    "MaxAudioUploadMB": 200,
    "MaxVideoUploadMB": 500
  },
  "MediaProcessor": {
    "BaseUrl": "http://localhost:8000",
    "TimeoutSeconds": 120,
    "Enabled": true
  },
  "AzureSpeech": {
    "Enabled": true,
    "SpeechToTextEnabled": true,
    "SpeechToTextKey": "",
    "SpeechToTextRegion": "eastus",
    "SpeechToTextApiVersion": "2025-10-15",
    "SpeechToTextLocale": "pt-BR",
    "SpeechToTextUseDiarization": true,
    "SpeechToTextMaxSpeakers": 2,
    "SpeechToTextUsePhraseList": true,
    "SpeechToTextPhraseList": [
      "Base de Sinistros",
      "BAS",
      "Opentech",
      "Operador BAS",
      "sinistro",
      "CEAGESP",
      "boletim de ocorrência",
      "B.O.",
      "placa",
      "roubo",
      "furto",
      "tombamento",
      "colisão",
      "jammer",
      "vassourinha",
      "rastreador",
      "gerenciadora de risco",
      "GR",
      "PRF",
      "PRE",
      "salvado",
      "perda total",
      "avaria",
      "transportadora",
      "motorista",
      "oitiva",
      "regulação"
    ],
    "SubscriptionKey": "",
    "Region": "eastus2",
    "Endpoint": "",
    "DeploymentName": "whisper",
    "Fallback": {
      "SpeechToTextKey": "",
      "SubscriptionKey": "",
      "Region": "eastus2",
      "Endpoint": ""
    }
  },
  "AzureOpenAI": {
    "Enabled": true,
    "ApiKey": "",
    "Endpoint": "",
    "DeploymentName": "gpt-4o",
    "Region": "eastus",
    "Fallback": {
      "ApiKey": "",
      "Endpoint": "",
      "Region": "eastus"
    }
  },
  "AzureTextAnalytics": {
    "Enabled": true,
    "Key": "",
    "Endpoint": ""
  }
}
